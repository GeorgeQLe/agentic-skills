{
  "name": "agentic-skills",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/skills-showcase",
    "packages/skillpacks"
  ],
  "scripts": {
    "skillpacks:build": "npm --workspace skillpacks run build",
    "skillpacks:list": "npm --workspace skillpacks run skillpacks:list",
    "skillpacks:verify": "npm --workspace skillpacks run verify:package",
    "skills-showcase:build": "pnpm --dir apps/skills-showcase build",
    "skills-showcase:test": "pnpm --dir apps/skills-showcase test",
    "skills-showcase:validate-data": "pnpm --dir apps/skills-showcase validate:data"
  }
}
