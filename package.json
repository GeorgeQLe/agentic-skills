{
  "name": "agentic-skills",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/skillpacks"
  ],
  "devDependencies": {
    "skillpacks": "workspace:*"
  },
  "scripts": {
    "exports:generate": "node scripts/generate-skills-catalog-export.mjs",
    "exports:check": "scripts/validate-skills-catalog-export.sh",
    "skillpacks:build": "npm --workspace packages/skillpacks run build",
    "skillpacks:list": "npm --workspace packages/skillpacks run skillpacks:list",
    "skillpacks:verify": "npm --workspace packages/skillpacks run verify:package",
    "skillpacks:verify-published": "npm --workspace packages/skillpacks run verify:published"
  }
}
