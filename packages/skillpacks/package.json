{
  "name": "skillpacks",
  "version": "0.1.11",
  "description": "CLI and packaged markdown skill library for Claude Code and OpenAI Codex.",
  "type": "module",
  "bin": {
    "gskp": "bin/skillpacks.mjs",
    "skillpacks": "bin/skillpacks.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GeorgeQLe/agentic-skills.git",
    "directory": "packages/skillpacks"
  },
  "bugs": {
    "url": "https://github.com/GeorgeQLe/agentic-skills/issues"
  },
  "homepage": "https://github.com/GeorgeQLe/agentic-skills#readme",
  "files": [
    "bin/",
    "src/",
    "dist/",
    "base/",
    "packs/",
    "scripts/pack.sh",
    "scripts/skill-links.sh",
    "scripts/skill-convention-bundle-audit.mjs",
    "scripts/skill-convention-registry.mjs",
    "scripts/upgrade-alignment-page.mjs",
    "scripts/upgrade-interrogation-page.mjs",
    "scripts/upgrade-design-tree-loop.mjs",
    "scripts/audit-alignment-pages.mjs",
    "scripts/open-html-page.mjs",
    "scripts/serve-alignment.mjs",
    "scripts/inject-tts.mjs",
    "scripts/alignment-tts-kokoro.js",
    "scripts/alignment-chart-snippets.js",
    "scripts/alignment-skip-list.txt",
    "scripts/alignment-bespoke-list.txt",
    "scripts/prepublish-auth-check.mjs",
    "assets/alignment-page-convention.md",
    "assets/interrogation-page-convention.md",
    "assets/design-tree-loop-convention.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:manifest && node scripts/build-package.mjs",
    "build:check": "node ../../scripts/skill-convention-bundle-audit.mjs && npm run build:manifest:check && node scripts/build-package.mjs --check",
    "build:manifest": "node scripts/build-skillpacks-manifest.mjs",
    "build:manifest:check": "node scripts/build-skillpacks-manifest.mjs --check",
    "pack:dry-run": "npm pack ./build --dry-run --json --silent",
    "prepublishOnly": "node scripts/prepublish-auth-check.mjs",
    "publish:preflight": "node scripts/prepublish-auth-check.mjs",
    "skillpacks:list": "node bin/skillpacks.mjs list",
    "test:node": "node --test test/*.test.mjs",
    "verify:package": "node bin/skillpacks.mjs --version && node bin/skillpacks.mjs list && npm run build:check && npm pack ./build --dry-run --json --silent",
    "verify:published": "bash scripts/verify-published-package.sh"
  },
  "keywords": [
    "ai",
    "agents",
    "claude-code",
    "codex",
    "skills"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
