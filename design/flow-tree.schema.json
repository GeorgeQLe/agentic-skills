{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-skills.local/design/flow-tree.schema.json",
  "title": "Product Design Flow Tree Manifest",
  "description": "Tracks pre-prototype user-flow, UX-variation, and UI-approval branches for one active product design flow.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic",
    "mode",
    "route",
    "source_artifacts",
    "branches"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v0.2"
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "product_path": {
      "type": "string",
      "pattern": "^research/[^/]+/$"
    },
    "mode": {
      "type": "string",
      "enum": ["flat", "product-path"]
    },
    "route": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "user-flow-map",
          "ux-variations",
          "ui-interview",
          "prototype",
          "consolidate-variations",
          "spec-interview"
        ]
      },
      "prefixItems": [
        { "const": "user-flow-map" },
        { "const": "ux-variations" },
        { "const": "ui-interview" },
        { "const": "prototype" },
        { "const": "consolidate-variations" },
        { "const": "spec-interview" }
      ],
      "minItems": 6,
      "maxItems": 6
    },
    "source_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "branches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/user_flow_branch"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      },
      "default": []
    },
    "prototype_build_plan": {
      "$ref": "#/$defs/prototype_build_plan"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "model_tree_ref": {
      "type": "string",
      "minLength": 1,
      "description": "DEPRECATED back-compat (pre-v0.2): single top-level path to a model-tree manifest. Superseded by per-user-flow-branch user_flow_branch.model_ref, which is now the primary state-model linkage. Retained, never required, route array unaffected."
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "ready-for-ui",
        "approved",
        "rejected",
        "retry-needed",
        "promoted-to-prototype",
        "consolidated"
      ]
    },
    "prototype_build_status": {
      "type": "string",
      "enum": [
        "pending",
        "built",
        "needs-revision",
        "deferred",
        "dropped"
      ]
    },
    "prototype_build_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts", "items"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prototype_build_item"
          }
        }
      }
    },
    "prototype_build_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "user_flow_branch_id", "ux_variation_id", "ui_experiment_id", "artifacts"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/prototype_build_status"
        },
        "user_flow_branch_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "ux_variation_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "ui_experiment_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "prototype_path": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "user_flow_branch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "artifacts", "ux_variations"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "model_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Primary (v0.2) per-user-flow-branch model attachment: repo-relative path to this branch's model-tree manifest (design/**/model-tree-{topic}-{branch}.yaml) owned by state-model. The domain/state/logic model is a property of the flow, so each user-flow branch attaches its own model. ux-variations does not grow UX branches until model_ref is present and its model confirmed."
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "ux_variations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ux_variation_branch"
          }
        }
      }
    },
    "ux_variation_branch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "artifacts", "ui_experiments"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "ui_experiments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ui_experiment"
          }
        }
      }
    },
    "ui_experiment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "artifacts"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "decision_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "branch_ref", "decision", "rationale", "recorded_at"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "branch_ref": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": ["approve", "reject", "retry", "modify"]
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Required only when decision is `modify`: repo-relative refs to the upstream node(s) to re-open (a user-flow branch id, or a branch's model_ref / model-tree manifest). Recording a modify returns each target to a pending status so its owning skill re-runs its 5-stage flow; descendant branches below the re-opened node are marked stale for re-validation. This is how validation flows back up the design tree."
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "decision": { "const": "modify" } }
          },
          "then": {
            "required": ["targets"],
            "properties": {
              "targets": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
