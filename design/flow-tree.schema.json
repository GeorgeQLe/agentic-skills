{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-skills.local/design/flow-tree.schema.json",
  "title": "Product Design Flow Tree Manifest",
  "description": "Tracks pre-prototype user-flow, UX-variation, and UI-approval branches for one active product design flow.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic",
    "mode",
    "route",
    "source_artifacts",
    "branches"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v0.1"
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "product_path": {
      "type": "string",
      "pattern": "^research/[^/]+/$"
    },
    "mode": {
      "type": "string",
      "enum": ["flat", "product-path"]
    },
    "route": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "user-flow-map",
          "ux-variations",
          "ui-interview",
          "prototype",
          "consolidate-variations",
          "spec-interview"
        ]
      },
      "prefixItems": [
        { "const": "user-flow-map" },
        { "const": "ux-variations" },
        { "const": "ui-interview" },
        { "const": "prototype" },
        { "const": "consolidate-variations" },
        { "const": "spec-interview" }
      ],
      "minItems": 6,
      "maxItems": 6
    },
    "source_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "branches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/user_flow_branch"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      },
      "default": []
    },
    "prototype_build_plan": {
      "$ref": "#/$defs/prototype_build_plan"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "ready-for-ui",
        "approved",
        "rejected",
        "retry-needed",
        "promoted-to-prototype",
        "consolidated"
      ]
    },
    "prototype_build_status": {
      "type": "string",
      "enum": [
        "pending",
        "built",
        "needs-revision",
        "deferred",
        "dropped"
      ]
    },
    "prototype_build_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts", "items"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prototype_build_item"
          }
        }
      }
    },
    "prototype_build_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "user_flow_branch_id", "ux_variation_id", "ui_review_id", "artifacts"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/prototype_build_status"
        },
        "user_flow_branch_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "ux_variation_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "ui_review_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "prototype_path": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "user_flow_branch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "artifacts", "ux_variations"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "ux_variations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ux_variation_branch"
          }
        }
      }
    },
    "ux_variation_branch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "artifacts", "ui_reviews"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "ui_reviews": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ui_review"
          }
        }
      }
    },
    "ui_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "artifacts"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "decision_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "branch_ref", "decision", "rationale", "recorded_at"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "branch_ref": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": ["approve", "reject", "retry"]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
