{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-skills.local/design/flow-tree.schema.json",
  "title": "Product Design Flow Tree Manifest",
  "description": "Tracks pre-prototype user-flow, UX-variation, UI-approval, platform-fit, and prototype-probe branches for one active product design flow. v0.3 adds deterministic branch-order metadata and progressive review guidance so branch selection is explicit instead of raw array-order dependent. v0.4 re-cuts the build leaf from `prototype` to `logic-wiring` (route position 4) and adds additive flow-walk fields on `ui_experiment`: a per-screen `build_ledger[]` (with its own `build_ledger_status` lifecycle) so the minimum-UI stop rule and park off-ramp are machine-expressible, a `cherry_pick_candidate` flag for consolidate-prototypes stage 1, and a per-screen `model_ref` so a screen can attach its state model. v0.5 adds optional `platform_fit` candidate/recommendation state and `prototype_build_item.platform_probe` metadata for thin platform-specific risk probes. The route stays a fixed 6-step tuple; state-model and Platform Fit remain off the route.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "topic",
    "mode",
    "route",
    "source_artifacts",
    "branches"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v0.5"
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "product_path": {
      "type": "string",
      "pattern": "^research/[^/]+/$"
    },
    "mode": {
      "type": "string",
      "enum": ["flat", "product-path"]
    },
    "route": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "user-flow-map",
          "ux-variations",
          "ui-interview",
          "logic-wiring",
          "consolidate-prototypes",
          "spec-interview"
        ]
      },
      "prefixItems": [
        { "const": "user-flow-map" },
        { "const": "ux-variations" },
        { "const": "ui-interview" },
        { "const": "logic-wiring" },
        { "const": "consolidate-prototypes" },
        { "const": "spec-interview" }
      ],
      "minItems": 6,
      "maxItems": 6
    },
    "source_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "branches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/user_flow_branch"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      },
      "default": []
    },
    "prototype_build_plan": {
      "$ref": "#/$defs/prototype_build_plan"
    },
    "platform_fit": {
      "$ref": "#/$defs/platform_fit"
    },
    "branch_order_override": {
      "$ref": "#/$defs/branch_order_override"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "model_tree_ref": {
      "type": "string",
      "minLength": 1,
      "description": "DEPRECATED back-compat (pre-v0.2): single top-level path to a model-tree manifest. Superseded by per-user-flow-branch user_flow_branch.model_ref, which is now the primary state-model linkage. Retained, never required, route array unaffected."
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "ready-for-ui",
        "approved",
        "rejected",
        "retry-needed",
        "promoted-to-prototype",
        "consolidated",
        "parked"
      ]
    },
    "prototype_build_status": {
      "type": "string",
      "enum": [
        "pending",
        "built",
        "needs-revision",
        "deferred",
        "dropped"
      ]
    },
    "platform_kind": {
      "type": "string",
      "enum": [
        "web_app",
        "mobile_web_pwa",
        "native_mobile",
        "native_desktop",
        "cli",
        "api",
        "sdk",
        "browser_extension",
        "marketplace_multi_sided",
        "integration_automation",
        "game_playable",
        "other"
      ]
    },
    "platform_fit_score": {
      "type": "string",
      "enum": ["high", "medium", "low", "rejected"]
    },
    "platform_fit_status": {
      "type": "string",
      "enum": ["recommended", "probe", "defer", "reject", "selected"]
    },
    "platform_fit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates", "recommendation"],
      "properties": {
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/platform_fit_candidate"
          }
        },
        "recommendation": {
          "$ref": "#/$defs/platform_fit_recommendation"
        }
      },
      "description": "v0.5 optional/additive Platform Fit Workshop output owned by `user-flow-map`: ranked platform candidates, thin probe decisions, and the recommended platform strategy."
    },
    "platform_fit_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "fit",
        "evidence_basis",
        "moment_of_need",
        "job_shape",
        "adoption_friction",
        "permission_or_trust_burden",
        "distribution_fit",
        "monetization_fit",
        "technical_leverage",
        "fatal_risks",
        "required_probe",
        "status"
      ],
      "properties": {
        "platform": {
          "$ref": "#/$defs/platform_kind"
        },
        "fit": {
          "$ref": "#/$defs/platform_fit_score"
        },
        "evidence_basis": {
          "type": "string",
          "minLength": 1
        },
        "moment_of_need": {
          "type": "string",
          "minLength": 1
        },
        "job_shape": {
          "type": "string",
          "minLength": 1
        },
        "adoption_friction": {
          "type": "string",
          "minLength": 1
        },
        "permission_or_trust_burden": {
          "type": "string",
          "minLength": 1
        },
        "distribution_fit": {
          "type": "string",
          "minLength": 1
        },
        "monetization_fit": {
          "type": "string",
          "minLength": 1
        },
        "technical_leverage": {
          "type": "string",
          "minLength": 1
        },
        "fatal_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_probe": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/platform_fit_status"
        }
      }
    },
    "platform_fit_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "decision_rationale"],
      "properties": {
        "primary": {
          "$ref": "#/$defs/platform_kind"
        },
        "companion": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/platform_kind"
          }
        },
        "defer": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/platform_kind"
          }
        },
        "reject": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/platform_kind"
          }
        },
        "decision_rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "platform_probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "probe_type", "risk_tested", "evidence_target", "non_visual"],
      "properties": {
        "platform": {
          "$ref": "#/$defs/platform_kind"
        },
        "probe_type": {
          "type": "string",
          "enum": [
            "web_clickable",
            "mobile_clickable",
            "cli_script",
            "api_mock_curl",
            "sdk_sample",
            "extension_simulation",
            "desktop_local_shell",
            "marketplace_two_sided_flow",
            "other"
          ]
        },
        "risk_tested": {
          "type": "string",
          "minLength": 1
        },
        "evidence_target": {
          "type": "string",
          "minLength": 1
        },
        "non_visual": {
          "type": "boolean",
          "description": "When true, this build item is an explicitly non-visual platform probe and may omit `ui_experiment_id`."
        }
      },
      "description": "v0.5 thin platform-probe metadata for build items that test platform-specific adoption, permission, distribution, monetization, or technical leverage risks without building full parallel products."
    },
    "build_ledger_status": {
      "type": "string",
      "enum": [
        "pending",
        "in-progress",
        "minimum-ui-reached",
        "wired",
        "parked"
      ],
      "description": "v0.4 flow-walk lifecycle for a single build-ledger entry. `build-ui-screens` advances a screen's batch through pending -> in-progress -> minimum-ui-reached (the visual stop rule fires); `logic-wiring` advances minimum-ui-reached -> wired once the flow step is clickable/state-backed. `parked` is the off-ramp for a screen deferred out of the current build pass."
    },
    "build_ledger_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "flow_step", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "flow_step": {
          "type": "string",
          "minLength": 1,
          "description": "The single flow step (one moment/screen-batch) this ledger entry tracks. One batch = one flow-step per the design-tree-loop ordered-intermediates rule."
        },
        "status": {
          "$ref": "#/$defs/build_ledger_status"
        },
        "elements_added": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Visual wireframe elements added in this batch, in build order."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "progressive_review_guidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_value_step",
        "primary_task_path",
        "staged_disclosure_notes",
        "evidence_required"
      ],
      "properties": {
        "first_value_step": {
          "type": "string",
          "minLength": 1,
          "description": "The first visible moment where the user receives meaningful value from this branch."
        },
        "primary_task_path": {
          "type": "string",
          "minLength": 1,
          "description": "The primary path to review before secondary controls, alternate states, or dense administrative surfaces."
        },
        "staged_disclosure_notes": {
          "type": "string",
          "minLength": 1,
          "description": "How review should introduce complexity progressively instead of presenting the full interface at once."
        },
        "evidence_required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Evidence required before moving deeper into the design tree or promoting the branch."
        }
      }
    },
    "prototype_build_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts", "items"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prototype_build_item"
          }
        }
      }
    },
    "branch_order_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "ordered_branch_ids", "override_rationale", "recorded_at"],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["user-flow", "ux-variation"],
          "description": "The branch level whose default journey/evaluation ordering was explicitly overridden by the user."
        },
        "parent_branch_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Required for UX-variation overrides: the user-flow branch whose child variation order is overridden."
        },
        "ordered_branch_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "override_rationale": {
          "type": "string",
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "scope": { "const": "ux-variation" } }
          },
          "then": {
            "required": ["parent_branch_id"]
          }
        }
      ]
    },
    "prototype_build_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "user_flow_branch_id", "ux_variation_id", "artifacts"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/prototype_build_status"
        },
        "user_flow_branch_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "ux_variation_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "ui_experiment_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "prototype_path": {
          "type": "string",
          "minLength": 1
        },
        "platform_probe": {
          "$ref": "#/$defs/platform_probe"
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "not": {
              "required": ["platform_probe"],
              "properties": {
                "platform_probe": {
                  "required": ["non_visual"],
                  "properties": {
                    "non_visual": { "const": true }
                  }
                }
              }
            }
          },
          "then": {
            "required": ["ui_experiment_id"]
          }
        }
      ]
    },
    "user_flow_branch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "status",
        "journey_stage",
        "journey_sequence",
        "priority_rationale",
        "progressive_review",
        "artifacts",
        "ux_variations"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "journey_stage": {
          "type": "string",
          "enum": [
            "discovery",
            "activation",
            "first-value",
            "ongoing-use",
            "recovery",
            "handoff"
          ],
          "description": "The journey stage this user-flow branch primarily covers. Used with journey_sequence for deterministic default branch ordering."
        },
        "journey_sequence": {
          "type": "integer",
          "minimum": 1,
          "description": "Ascending default order for user-flow branch selection within the journey, unless an explicit user override is recorded."
        },
        "priority_rationale": {
          "type": "string",
          "minLength": 1,
          "description": "Why this branch has its current journey order or override priority."
        },
        "progressive_review": {
          "$ref": "#/$defs/progressive_review_guidance"
        },
        "model_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Primary (v0.2+) per-user-flow-branch model attachment: repo-relative path to this branch's model-tree manifest (design/**/model-tree-{topic}-{branch}.yaml) owned by state-model. The domain/state/logic model is a property of the flow, so each user-flow branch attaches its own model. ux-variations does not grow UX branches until model_ref is present and its model confirmed."
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "ux_variations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ux_variation_branch"
          }
        }
      }
    },
    "ux_variation_branch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "status",
        "evaluation_priority",
        "activation_fit",
        "first_value_fit",
        "priority_rationale",
        "progressive_review",
        "artifacts",
        "ui_experiments"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "evaluation_priority": {
          "type": "integer",
          "minimum": 1,
          "description": "Ascending priority for evaluating UX variation branches within a selected user-flow branch."
        },
        "activation_fit": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "How well this variation supports activation."
        },
        "first_value_fit": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "How directly this variation gets the user to the first-value moment."
        },
        "priority_rationale": {
          "type": "string",
          "minLength": 1,
          "description": "Why this variation has its evaluation priority and fit scores."
        },
        "progressive_review": {
          "$ref": "#/$defs/progressive_review_guidance"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "ui_experiments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ui_experiment"
          }
        }
      }
    },
    "ui_experiment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "artifacts"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "experiment_path": {
          "type": "string",
          "minLength": 1,
          "description": "Repo-relative route or experiment directory path for a clickable UI experiment output."
        },
        "review_evidence": {
          "type": "string",
          "minLength": 1,
          "description": "Concise evidence note or repo-relative review artifact proving the clickable UI experiment was reviewed."
        },
        "decision_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "build_ledger": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/build_ledger_entry"
          },
          "description": "v0.4 flow-walk: ordered per-screen build ledger written by `build-ui-screens` (one entry per flow-step batch) and advanced by `logic-wiring`. Makes the minimum-UI stop rule and park off-ramp machine-expressible. Optional/additive."
        },
        "cherry_pick_candidate": {
          "type": "boolean",
          "description": "v0.4 flow-walk: marks this screen/experiment as a candidate for `consolidate-prototypes` stage-1 cherry-pick (e.g. a parked or partial screen worth stitching into the canonical flow). Optional/additive."
        },
        "model_ref": {
          "type": "string",
          "minLength": 1,
          "description": "v0.4 flow-walk (cherry-pick from Proposal A open-Q#1): repo-relative path to this screen's state-model manifest, attached just-in-time when state-model runs against a promoted flow. Per-screen counterpart to user_flow_branch.model_ref. Optional/additive."
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "branch_ref", "decision", "rationale", "recorded_at"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "branch_ref": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": ["approve", "reject", "retry", "modify"]
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Required only when decision is `modify`: repo-relative refs to the upstream node(s) to re-open (a user-flow branch id, or a branch's model_ref / model-tree manifest). Recording a modify returns each target to a pending status so its owning skill re-runs its 5-stage flow; descendant branches below the re-opened node are marked stale for re-validation. This is how validation flows back up the design tree."
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "decision": { "const": "modify" } }
          },
          "then": {
            "required": ["targets"],
            "properties": {
              "targets": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
